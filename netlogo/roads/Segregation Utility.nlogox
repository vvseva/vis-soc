<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[extensions [ gis ]

breed [families family]
breed [venues venue]
breed [parks park]
undirected-link-breed [rays ray]

globals [
  percent-similar
  average-utility
  colors
  
  road-dataset
  water-dataset
  building-dataset
  
  percent-unhappy
  
    ;; MASSEY & DENTON (1988) SEGREGATION DIMENSIONS
  index-exposure
  index-dissimilarity
  index-clustering
  index-centrality
  index-concentration
  
  ;; OPTIMIZATION: Cache the patches where turtles can live
  habitable-patches
  temp-venue
]

;; LOGIC VARIABLE: Stores "True" if the patch is a road/water, 
;; independent of the visual pcolor.
;; traffic records how many turtles traveled by that road patch.
patches-own [ 
  is-road? 
  traffic 
  is-building?
  is-river?
  saved-color
  is-green?
  my-park-id
]

families-own [
  happy?
  my-utility          ;; The calculated utility score (incorporating logit error)
  
  similar-nearby      ;; Raycast visible similar neighbors
  total-nearby        ;; Total visible neighbors

  ;; Standard variables
  my-catchment-distance
  my-adventurousness
  my-commitment
  visited-venues
  visited-parks       ;; New tracking for park attendees
]

venues-own [
  my-venue-exclusivity
  my-venue-obligatoriness
  my-attendees        ;; An agentset of families currently visiting this venue
]

parks-own [
  my-patches          ;; The set of patches representing the park's physical area
  my-attendees        ;; An agentset of families currently visiting this park
]

to setup
  ;; 1. Handle World Resizing
  ifelse road-scenario = "real-norrkoping" [
    resize-world 0 500 0 200
    set-patch-size 2
  ]
  [
    resize-world -25 25 -25 25
    set-patch-size 8
  ]

  ;; 2. Standard Setup
  clear-all
  set temp-venue nobody
  set colors [red green yellow blue orange]
  ifelse random-seed? [
    random-seed 42] [
    random-seed new-seed
  ]

  ;; 3. Draw the Map
  ;; We wrap this in no-display to speed up the drawing process
  no-display
  draw-selected-scenario
  
  ;; 4. Cache Habitable Patches
  ifelse road-scenario = "real-norrkoping" and file-exists? "buildings.shp" [
    set habitable-patches patches with [is-building? and not is-river?]
  ]
  [
    set habitable-patches patches with [not is-road? and not is-river?]
  ]

  setup-parks
  setup-venues
  setup-families

  evaluate-venues-and-parks 
  update-families
  update-globals
  reset-ticks
  display ;; Force a display update after everything is ready
end

to go
  evaluate-venues-and-parks
  move-unhappy-families
  update-families
  update-globals
  tick
end

;; --- GENERATION & SETUP ---

to setup-parks
  create-parks parks-number [
    set shape "tree"
    set color green
    set size 2
    move-to one-of habitable-patches
    ;; Grow park to occupy multiple patches
    set my-patches (patches in-radius 1.5) with [not is-road? and not is-river?]
    ask my-patches [
      set pcolor green + 2
      set is-green? true
      set my-park-id [who] of myself
    ]
    set my-attendees (turtle-set nobody)
  ]
end

to setup-venues
  create-venues venues-number [
    set shape "house"
    set color (item (random number-of-ethnicities) colors)
    set size 2
    move-to one-of habitable-patches
    set my-venue-exclusivity venue-exclusivity
    set my-venue-obligatoriness 1
    set my-attendees (turtle-set nobody)
  ]
end

to setup-families
  let available-spots count habitable-patches
  let target-population floor (available-spots * (density-percent / 100))

  if target-population > 0 [
    ask n-of target-population habitable-patches [
      sprout-families 1 [
        set color (item (random number-of-ethnicities) colors)
        set shape "person"
        set size 1.5
        set happy? true
        
        set my-catchment-distance venue-catchment-distance
        set my-adventurousness random-float 1
        set my-commitment random-float 1
        
        set visited-venues (turtle-set nobody)
        set visited-parks (turtle-set nobody)
      ]
    ]
  ]
end

to draw-selected-scenario
  ;; Reset world state
  ask patches [ 
    set pcolor black 
    set is-road? false 
    set is-building? false
    set is-river? false
    set is-green? false
    set my-park-id nobody
    set traffic 0      
    set saved-color black
  ]

  (ifelse
    road-scenario = "empty" [
      ask patches [ set pcolor black ]
    ]

    road-scenario = "grid" [
      ask patches [
        if (pxcor mod 8 = 0) or (pycor mod 8 = 0) [ 
          set pcolor brown 
          set is-road? true
        ]
      ]
    ]

    road-scenario = "norrkoping" [
      ask patches [
        if (pxcor mod 12 = 0) or (pycor mod 12 = 0) [ 
          set pcolor brown 
          set is-road? true
        ]
        if abs (pycor - ( 8 * sin (pxcor * 5) )) < 2 [ 
          set pcolor blue 
          set is-road? false
          set is-river? true
        ]
        if abs (pxcor + 5) < 1 [ 
          set pcolor brown 
          set is-road? true
        ]
      ]
    ]

    road-scenario = "stockholm" [
      ask patches [
        let dist distancexy 0 0
        if dist > 8 and dist < 13 [ 
          set pcolor blue 
          set is-road? false
          set is-river? true
        ]
        if (pxcor mod 10 = 0) or (pycor mod 10 = 0) [ 
          set pcolor brown 
          set is-road? true
        ]
      ]
    ]

    road-scenario = "real-norrkoping" [
      ask patches [set pcolor gray + 4]
      ;; A. Draw Waterways (Blue)
      ifelse ( file-exists? "waterways.shp" ) [
        set water-dataset gis:load-dataset "waterways.shp"
        gis:set-world-envelope (gis:envelope-of water-dataset)
        
        gis:set-drawing-color blue
        gis:draw water-dataset 1
        display
        
        foreach gis:feature-list-of water-dataset [ feature ->
          ask patches gis:intersecting feature [ 
            set is-river? true
            set is-road? false
            set pcolor blue
          ]
        ]
      ] [ ]

      ;; B. Draw Roads (Brown)
      ifelse ( file-exists? "roads.shp" ) [
        set road-dataset gis:load-dataset "roads.shp"
        gis:set-world-envelope (gis:envelope-of road-dataset)
        
        gis:set-drawing-color brown
        gis:draw road-dataset 1
        display
        load-gis-logic road-dataset
      ] [ ]

      ;; C. Draw Buildings (Orange)
      ifelse ( file-exists? "buildings.shp" ) [
        set building-dataset gis:load-dataset "buildings.shp"
        gis:set-world-envelope (gis:envelope-of building-dataset)
        
        gis:set-drawing-color orange
        gis:fill building-dataset 1.0
        display
        
        foreach gis:feature-list-of building-dataset [ feature ->
          ask patches gis:intersecting feature [ 
            set is-building? true
            set pcolor orange
          ]
        ]
      ] [ ]
    ]
  )
end

to load-gis-logic [ dataset ]
  foreach gis:feature-list-of dataset [ feature ->
    ask patches gis:intersecting feature [ 
      if not is-river? [ set is-road? true ]
    ]
  ]
end

;; --- LOGIC UPDATES ---

to evaluate-venues-and-parks
  ;; 1. Families choose venues and parks
  ask families [
    ;; VENUES
    let possible-venues venues in-radius my-catchment-distance
    let open-venues-group possible-venues with [color = [color] of myself]
    let open-venues-adventure possible-venues with [color != [color] of myself and my-venue-exclusivity < [my-adventurousness] of myself]

    let open-venues (turtle-set open-venues-group open-venues-adventure )
    set visited-venues open-venues with [1 - my-venue-obligatoriness < [my-commitment] of myself]
    
    ;; PARKS (Using the new specific park catchment distance)
    set visited-parks parks in-radius park-catchment-distance
  ]

  ;; 2. Venues update their attendee list
  ask venues [
    set my-attendees families with [member? myself visited-venues]
  ]
  
  ;; 3. Parks update their attendee list
  ask parks [
    set my-attendees families with [member? myself visited-parks]
  ]
end

to update-families
  ask families [
    ;; --- X1: Agents in my Neighborhood (Raycast Vision) ---
    let candidates other families in-radius neighborhood-distance
    let visible-candidates candidates with [ has-line-of-sight? myself ]
    
    set total-nearby count visible-candidates
    set similar-nearby count visible-candidates with [color = [color] of myself]
    let val1 calculate-similarity visible-candidates

    ;; --- X2: Agents in my Venues ---
    let group2 (turtle-set [my-attendees] of visited-venues)
    set group2 other group2 ;; Remove myself from the count
    let val2 calculate-similarity group2

    ;; --- X3: Agents around my Venues ---
    let group3 (turtle-set [other families in-radius neighborhood-distance] of visited-venues)
    let val3 calculate-similarity group3

    ;; --- X4: Agents coming to my Neighborhood ---
    let local-venues venues in-radius neighborhood-distance
    let group4 (turtle-set [my-attendees] of local-venues)
    set group4 other group4 
    let val4 calculate-similarity group4

    ;; --- X5: Agents in my Parks (New Variable per constraints) ---
    let group5 (turtle-set [my-attendees] of visited-parks)
    set group5 other group5
    let val5 calculate-similarity group5

    ;; --- CALCULATE DISCRETE CHOICE UTILITY DISTRIBUTION ---
    ;; Formula: V = Sum(Beta_i * X_i) + Epsilon
    let weights-sum (beta1-neighbors + beta2-venue-group + beta3-venue-loc + beta4-home-venues + beta5-park-group)
    
    ;; Introduce error term to create the discrete probability distribution based on logit structure
    let eps random-normal 0 0.1 
    
    let weighted-score (val1 * beta1-neighbors) + 
                       (val2 * beta2-venue-group) + 
                       (val3 * beta3-venue-loc) + 
                       (val4 * beta4-home-venues) + 
                       (val5 * beta5-park-group)

    ifelse weights-sum > 0 [
      set my-utility (weighted-score / weights-sum) + eps
    ]
    [
      set my-utility eps
    ]
  ]
end

;; Calculates the percentage of agents in a group that share my color
to-report calculate-similarity [ target-group ]
  if not any? target-group [ report 0.5 ]

  let total-count count target-group
  let similar-count count target-group with [color = [color] of myself]
  report (similar-count / total-count)
end

;; --- MOVEMENT & HAPPINESS DISTRIBUTION ---

to move-unhappy-families
  ;; Calculate exactly 10% of the population
  let num-to-move ceiling (count families * 0.10)
  
  if num-to-move > 0 [
    ;; Sort ascending by utility (taking the bottom 10%)
    let sorted-families sort-by [ [f1 f2] -> [my-utility] of f1 < [my-utility] of f2 ] families
    let least-happy sublist sorted-families 0 num-to-move
    
    ;; Set states for visualization
    ask families [ set happy? true ]
    
    ;; Force movement of the bottom 10%
    ask turtle-set least-happy [ 
      set happy? false
      find-new-spot 
    ]
  ]
end

to find-new-spot
  let max-search-radius travel-distance
  
  if any? patches in-radius travel-distance with [is-road?] [
    set max-search-radius (travel-distance * road-multiplier)
  ]
  
  let candidates habitable-patches in-radius max-search-radius with [not any? turtles-on self]
  if not any? candidates [ stop ]
  
  let target nobody
  
  ifelse real-travel? [
    let reachable-candidates candidates with [ is-reachable? myself self ]
    if any? reachable-candidates [
      set target one-of reachable-candidates
    ]
  ]
  [
    let tries 0
    while [target = nobody and tries < 20] [
      let potential-spot one-of candidates
      if is-reachable? self potential-spot [
        set target potential-spot
      ]
      set tries tries + 1
    ]
  ]
  
  if target != nobody [
    let final-path get-path-patches target
    ask final-path with [is-road?] [
      set traffic traffic + 1
    ]
    move-to target
  ]
end

to-report has-line-of-sight? [ target ]
  let dist distance target
  if dist = 0 [ report true ]

  let ang towards target
  let step 1.0
  let current-dist step

  while [current-dist < dist] [
    let p patch-at-heading-and-distance ang current-dist
    
    ;; Rivers block vision
    if p != nobody and [is-river?] of p [ report false ]
    
    ;; OPTIMIZATION: Check against the habitable-set (blocks roads based on selected constraints)
    if not member? p habitable-patches [ report false ]
    
    set current-dist current-dist + step
  ]
  report true
end

;; Helper reporter: Extracts the actual patches intersected on a straight line
to-report get-path-patches [ target ]
  let dist distance target
  if dist = 0 [ report patch-set patch-here ]
  let ang towards target
  let step 0.5 ;; Finer resolution to guarantee no missed road patches
  let current-dist step
  let p-set (patch-set patch-here)
  
  while [current-dist <= dist] [
    let p patch-at-heading-and-distance ang current-dist
    if p != nobody [ set p-set (patch-set p-set p) ]
    set current-dist current-dist + step
  ]
  report p-set
end

to-report is-reachable? [ turtle-agent patch-agent ]
  let actual-dist [distance patch-agent] of turtle-agent
  let p-set [get-path-patches patch-agent] of turtle-agent
  let total-p count p-set
  
  if total-p = 0 [ report false ]
  
  ;; Rivers block mobility completely
  if any? p-set with [is-river?] [ report false ]
  
  ;; Automatically reachable if within base travel budget
  if actual-dist <= travel-distance [ report true ]
  
  ;; For patches further away, check if roads make them reachable
  let road-p count p-set with [is-road?]
  let f (road-p / total-p)
  
  ;; Roads cost 1/road-multiplier, normal patches cost 1
  let effective-cost actual-dist * ( (1 - f) + (f / road-multiplier) )
  
  report effective-cost <= travel-distance
end


;; --- STATISTICAL METRICS: MASSEY & DENTON (1988) ---
to calculate-segregation-dimensions
  ;; For consistent binary indices, we compare "Group X" (item 0 in the colors list, e.g., red) 
  ;; against "Group Y" (all other groups combined).
  let gx-color item 0 colors
  let pop-x count families with [color = gx-color]
  let pop-y count families with [color != gx-color]
  let pop-t count families
  
  if pop-x = 0 or pop-y = 0 or pop-t = 0 [ stop ]

  ;; 1. EXPOSURE (Isolation Index for Group X)
  ;; Measures the experience of the average person: the probability of sharing a unit with their own group.
  ;; We rely on the established line-of-sight raycast `similar-nearby` as the spatial neighborhood unit.
  let iso-sum sum [ similar-nearby / total-nearby ] of families with [color = gx-color and total-nearby > 0]
  set index-exposure (iso-sum / pop-x)

  ;; Define demographic "Tracts" using a grid approximation.
  ;; We place anchor points every 10 patches and analyze a radius of 5 (roughly a 10x10 block).
  let tracts patches with [ (pxcor mod 10 = 0) and (pycor mod 10 = 0) ]
  let total-area count habitable-patches
  
  ;; 2. UNEVENNESS (Dissimilarity Index, D)
  let d-sum 0
  ;; 3. CONCENTRATION (Delta Index, Δ)
  let delta-sum 0
  
  ask tracts [
    let local-fam families in-radius 5
    let x_i count local-fam with [color = gx-color]
    let y_i count local-fam with [color != gx-color]
    let a_i count (patches in-radius 5) with [member? self habitable-patches]
    
    set d-sum d-sum + abs ( (x_i / pop-x) - (y_i / pop-y) )
    if total-area > 0 [
       set delta-sum delta-sum + abs ( (x_i / pop-x) - (a_i / total-area) )
    ]
  ]
  set index-dissimilarity (d-sum / 2)
  set index-concentration (delta-sum / 2)
  
  ;; 4. CENTRALITY (Relative Centralization Index, RCI)
  ;; Sorts the established tracts by distance to the city center point (0,0)
  ;; and computes the cumulative spatial distribution curve between the two groups.
;   let sorted-tracts sort-by [ [t1 t2] -> [distancexy 0 0] of t1 < [distancexy 0 0] of t2 ] tracts
;   let cum-X 0
;   let cum-Y 0
;   let rci-sum 0
  
;   foreach sorted-tracts [ t ->
;     let local-fam [families in-radius 5] of t
;     let p-x (count local-fam with [color = gx-color]) / pop-x
;     let p-y (count local-fam with [color != gx-color]) / pop-y
    
;     let prev-cum-X cum-X
;     let prev-cum-Y cum-Y
    
;     set cum-X cum-X + p-x
;     set cum-Y cum-Y + p-y
    
;     set rci-sum rci-sum + (prev-cum-X * cum-Y) - (cum-X * prev-cum-Y)
;   ]
;   set index-centrality rci-sum
  
  ;; 5. CLUSTERING (Spatial Proximity Index, SP)
  ;; Exhaustive O(N^2) evaluation for exponential distance decay is computationally crushing. 
  ;; We execute a Monte Carlo approximation by sampling 400 random agents from each group per tick.
  let n_random 400
  let sample-x n-of (ifelse-value (pop-x > n_random) [n_random] [pop-x]) families with [color = gx-color]
  let sample-y n-of (ifelse-value (pop-y > n_random) [n_random] [pop-y]) families with [color != gx-color]
  let sample-t n-of (ifelse-value (pop-t > n_random) [n_random] [pop-t]) families
  
  let pxx mean [ mean [ exp (- distance myself) ] of sample-x ] of sample-x
  let pyy mean [ mean [ exp (- distance myself) ] of sample-y ] of sample-y
  let ptt mean [ mean [ exp (- distance myself) ] of sample-t ] of sample-t
  
  ifelse ptt > 0 [
     set index-clustering ( (pop-x * pxx + pop-y * pyy) / (pop-t * ptt) )
  ] [
     set index-clustering 0
  ]
end

to update-globals
  let sum-similar sum [similar-nearby] of families
  let sum-total sum [total-nearby] of families

  ifelse sum-total = 0
    [ set percent-similar 100 ]
    [ set percent-similar (sum-similar / sum-total) * 100 ]

  set average-utility mean [my-utility] of families
  
  
  set percent-unhappy (count families + 1) / (count families with [not happy?] + 1)
  
  calculate-segregation-dimensions
end

;; --- MANUAL PLACEMENT ---

to place-temporary-venue
    if mouse-down? [
    ask patches with [pcolor = lime] [ set pcolor black ]
    let target-patch patch mouse-xcor mouse-ycor
    ifelse temp-venue = nobody [
      create-venues 1 [
        set temp-venue self
        set shape "house"
        move-to target-patch
      ]
    ]
    [
      ask temp-venue [
        move-to target-patch
      ]
    ]
    ask temp-venue [
      set color (item (random number-of-ethnicities) colors) 
      set my-venue-exclusivity venue-exclusivity
      set my-venue-obligatoriness 1
      ask patches in-radius venue-catchment-distance [
        set pcolor lime
      ]
    ]
    while [mouse-down?] [ every 0.1 [] ]
    display
  ]
end

to confirm-venue-placement
  ifelse temp-venue != nobody [
    set temp-venue nobody
    ask patches [ set pcolor black ]
    ask venues [ set pcolor white ]
    evaluate-venues-and-parks
    update-families
    update-globals
    user-message "Venue Confirmed."
  ]
  [
    user-message "No temporary venue found to confirm."
  ]
end

to draw-roads
  if mouse-down? [
    ask patch mouse-xcor mouse-ycor [
      set pcolor brown
      set is-road? true
      set is-river? false
      set traffic 0
      ask families-here [ find-new-spot ]
    ]
    display
  ]
end

to remove-roads
  if mouse-down? [
    ask patch mouse-xcor mouse-ycor [
      ;; Remove roads
      if pcolor = brown or is-road? [ 
         set pcolor black 
         set is-road? false 
         set traffic 0
      ]
      
      ;; Remove parks
      if pcolor = (green + 2) or is-green? [
         set pcolor black
         set is-green? false
         set my-park-id nobody
         ask parks [
           set my-patches my-patches with [self != myself]
         ]
      ]
      
      ;; Remove venues and park core nodes
      ask venues-here [ die ]
      ask parks-here [ die ]
    ]
    display
  ]
end

to grow-parks
  if mouse-down? [
    ask patch mouse-xcor mouse-ycor [
      set pcolor green + 2
      set is-green? true
      set is-road? false
      set is-river? false
      
      ifelse any? parks in-radius 10 [
        let nearest-park min-one-of (parks in-radius 10) [distance myself]
        if nearest-park != nobody [
          set my-park-id [who] of nearest-park
          ask nearest-park [
            set my-patches (patch-set my-patches myself)
          ]
        ]
      ]
      [
        ;; If no parks exist within 5 patches distance, spawn a core park node here
        sprout-parks 1 [
          set shape "tree"
          set color green
          set size 2
          set my-patches (patch-set patch-here)
          set my-attendees (turtle-set nobody)
        ]
        set my-park-id [who] of one-of parks-here
      ]
    ]
    display
  ]
end]]></code>
  <widgets>
    <view x="295" wrappingAllowedX="true" y="10" frameRate="30.0" minPycor="-25" height="404" showTickCounter="true" patchSize="8.0" fontSize="10" wrappingAllowedY="true" width="404" tickCounterLabel="ticks" maxPycor="25" updateMode="1" maxPxcor="25" minPxcor="-25"></view>
    <plot x="10" autoPlotX="true" yMax="100.0" autoPlotY="true" yAxis="%" y="238" xMin="0.0" height="175" legend="false" xMax="25.0" yMin="0.0" width="249" xAxis="time" display="Percent Similar">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="percent" color="-2674135" legend="true">
        <setup></setup>
        <update>plot percent-similar</update>
      </pen>
    </plot>
    <plot x="10" autoPlotX="true" yMax="100.0" autoPlotY="false" yAxis="%" y="418" xMin="0.0" height="175" legend="false" xMax="25.0" yMin="0.0" width="249" xAxis="time" display="Percent Unhappy">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="percent" color="-10899396" legend="true">
        <setup></setup>
        <update>plot percent-unhappy</update>
      </pen>
    </plot>
    <slider x="15" step="10" y="62" max="100" width="225" display="density-percent" height="50" min="1" direction="Horizontal" default="71.0" variable="density-percent"></slider>
    <slider x="15" step="1.0" y="119" max="100.0" width="225" display="%-similar-wanted" height="50" min="0.0" direction="Horizontal" default="30.0" variable="%-similar-wanted" units="%"></slider>
    <button x="34" y="14" height="40" disableUntilTicks="false" forever="false" kind="Observer" width="80" display="setup">setup</button>
    <button x="124" y="14" height="40" disableUntilTicks="true" forever="true" kind="Observer" width="80" display="go">go</button>
    <slider x="35" step="1" y="605" max="5" width="192" display="number-of-ethnicities" height="50" min="2" direction="Horizontal" default="2.0" variable="number-of-ethnicities"></slider>
    <slider x="15" step="1" y="176" max="100" width="225" display="%-different-wanted" height="50" min="0" direction="Horizontal" default="0.0" variable="%-different-wanted" units="%"></slider>
    <slider x="244" step="1" y="605" max="20" width="173" display="neighborhood-distance" height="50" min="1" direction="Horizontal" default="4.0" variable="neighborhood-distance"></slider>
    <slider x="815" step="1" y="15" max="10" width="173" display="venues-number" height="50" min="0" direction="Horizontal" default="4.0" variable="venues-number"></slider>
    <slider x="815" step="1" y="103" max="20" width="173" display="venue-catchment-distance" height="50" min="0" direction="Horizontal" default="5.0" variable="venue-catchment-distance"></slider>
    <slider x="815" step="0.1" y="178" max="1" width="222" display="venue-exclusivity" height="50" min="0.0" direction="Horizontal" default="1.0" variable="venue-exclusivity"></slider>
    <chooser x="815" y="316" height="60" variable="new-venue-color" current="0" width="157" display="new-venue-color">
