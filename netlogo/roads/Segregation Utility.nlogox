<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="true">
  <code><![CDATA[extensions [ gis ]

breed [families family]
breed [venues venue]
breed [parks park]
undirected-link-breed [rays ray]

globals [
  percent-similar
  average-utility
  colors
  
  road-dataset
  water-dataset
  building-dataset
  
  percent-unhappy
  
  ;; MASSEY & DENTON (1988) SEGREGATION DIMENSIONS
  index-exposure
  index-dissimilarity
  index-clustering
  index-centrality
  index-concentration
  
  ;; OPTIMIZATION CACHES
  habitable-patches
  temp-venue
  buildings-enabled?
  environment-changed?
  last-travel-distance
  last-road-multiplier
  last-neighborhood-distance
]

patches-own [ 
  is-road? 
  traffic 
  is-building?
  is-river?
  saved-color
  is-green?
  my-park-id
  my-commuters
  tract-habitable-count  
  is-habitable?      ;; OPTIMIZATION: O(1) checking if patch allows movement
]

families-own [
  happy?
  my-utility          
  
  similar-nearby      
  total-nearby        

  my-catchment-distance
  my-adventurousness
  my-commitment
  visited-venues
  visited-parks       
  visited-roads
]

venues-own [
  my-venue-exclusivity
  my-venue-obligatoriness
  my-attendees        
]

parks-own [
  my-patches          
  my-attendees        
]

to setup
  ;; 1. Handle World Resizing
  ifelse road-scenario = "real-norrkoping" [
    resize-world 0 500 0 200
    set-patch-size 2
  ]
  [
    resize-world -25 25 -25 25
    set-patch-size 8
  ]

  ;; 2. Standard Setup
  clear-all
  set temp-venue nobody
  set colors [red green yellow blue orange]
  ifelse random-seed? [ random-seed 42 ] [ random-seed new-seed ]

  set buildings-enabled? (road-scenario = "real-norrkoping" and file-exists? "buildings.shp")
  set environment-changed? false
  set last-travel-distance travel-distance
  set last-road-multiplier road-multiplier
  set last-neighborhood-distance neighborhood-distance

  ;; 3. Draw the Map
  no-display
  draw-selected-scenario

  ;; 4. Cache Habitable Patches
  ask patches [ set is-habitable? false ]
  ifelse buildings-enabled? [
    set habitable-patches patches with [is-building? and not is-river?]
  ]
  [
    set habitable-patches patches with [not is-road? and not is-river?]
  ]
  ask habitable-patches [ set is-habitable? true ]

  initialize-tract-habitable-counts

  setup-parks
  setup-venues
  setup-families
  
  apply-intervention-scenario

  evaluate-venues-and-parks 
  update-families
  update-globals
  reset-ticks
  display 
end

to go
  ;; Check if sliders have changed
  if (travel-distance != last-travel-distance) or 
     (road-multiplier != last-road-multiplier) or 
     (neighborhood-distance != last-neighborhood-distance) [
    set environment-changed? true
    set last-travel-distance travel-distance
    set last-road-multiplier road-multiplier
    set last-neighborhood-distance neighborhood-distance
  ]

  if environment-changed? [
    evaluate-venues-and-parks
    initialize-tract-habitable-counts
    set environment-changed? false
  ]

  move-unhappy-families
  update-families
  update-globals
  tick
end

;; --- ROAD TRAVERSAL ALGORITHM ---

;; Calculates the exact reachable polygon using a flood-fill budget methodology
to-report get-reachable-network [ center-patch max-base-dist road-mult ]
  ;; 1. Base travel radius (Flood fill step-by-step respecting rivers)
  let active-patches (patch-set center-patch)
  let reached-patches active-patches
  let current-step 0
  
  while [current-step < max-base-dist] [
    let next-patches (patch-set [neighbors with [not is-river?]] of active-patches) with [not member? self reached-patches]
    set reached-patches (patch-set reached-patches next-patches)
    set active-patches next-patches
    set current-step current-step + 1
  ]
  
  ;; 2. Identify initial roads within base walking distance
  let active-roads reached-patches with [is-road?]
  let found-roads active-roads
  
  ;; 3. Propagate strictly along roads using the multiplier budget
  ;; For each propagation step, budget decreases by 1
  let budget (max-base-dist * road-mult)
  while [budget > 0 and any? active-roads] [
    let next-roads (patch-set [neighbors with [is-road? and not is-river?]] of active-roads) with [not member? self found-roads]
    set found-roads (patch-set found-roads next-roads)
    set active-roads next-roads
    set budget budget - 1
  ]
  
  ;; 4. Include off-road access (patches immediately adjacent to reached roads so agents can step off to a venue)
  let off-road-access (patch-set [neighbors with [not is-river?]] of found-roads)
  
  report (patch-set reached-patches found-roads off-road-access)
end


;; --- GENERATION & SETUP ---

to setup-parks
  create-parks parks-number [
    set shape "tree"
    set color green
    set size 2
    move-to one-of habitable-patches
    set my-patches (patches in-radius 1.5) with [not is-road? and not is-river?]
    ask my-patches [
      set pcolor green + 2
      set is-green? true
      set my-park-id [who] of myself
    ]
    set my-attendees (turtle-set nobody)
  ]
end

to setup-venues
  create-venues venues-number [
    set shape "house"
    set color (item (random number-of-ethnicities) colors)
    set size 2
    move-to one-of habitable-patches
    set my-venue-exclusivity venue-exclusivity
    set my-venue-obligatoriness 1
    set my-attendees (turtle-set nobody)
  ]
end

to setup-families
  let available-spots count habitable-patches
  let target-population floor (available-spots * (density-percent / 100))

  if target-population > 0 [
    ask n-of target-population habitable-patches [
      sprout-families 1 [
        ifelse random-float 100 < proportion-majority
        [ set color item 0 colors ] 
        [ set color item (1 + random (number-of-ethnicities - 1)) colors ] 
        set shape "person"
        set size 1.5
        set happy? true
        
        set my-catchment-distance venue-catchment-distance
        set my-adventurousness random-float 1
        set my-commitment random-float 1
        
        set visited-venues (turtle-set nobody)
        set visited-parks (turtle-set nobody)
        set visited-roads (patch-set nobody)
      ]
    ]
  ]
end

to draw-selected-scenario
  ask patches [ 
    set pcolor black 
    set is-road? false 
    set is-building? false
    set is-river? false
    set is-green? false
    set my-park-id nobody
    set traffic 0      
    set saved-color black
    set my-commuters (turtle-set nobody)
  ]

  (ifelse
    road-scenario = "empty" [ ask patches [ set pcolor black ] ]

    road-scenario = "grid" [
      ask patches [
        if (pxcor mod 8 = 0) or (pycor mod 8 = 0) [ 
          set pcolor brown 
          set is-road? true
        ]
      ]
    ]

    road-scenario = "isolated-communities" [
      ask patches [
        if abs pxcor < 2 or abs pycor < 2 [
          set pcolor blue
          set is-river? true
        ]
        if (pxcor mod 7 = 0) or (pycor mod 7 = 0) [
          if not is-river? [
            set pcolor brown
            set is-road? true
          ]
        ]
      ]
    ]

    road-scenario = "connected-communities" [
      ask patches [
        if abs pxcor < 2 or abs pycor < 2 [
          set pcolor blue
          set is-river? true
        ]
        if (pxcor mod 5 = 0) or (pycor mod 5 = 0) [
          set pcolor brown
          set is-road? true
          set is-river? false 
        ]
      ]
    ]

    road-scenario = "city-center-suburbia" [
      ask patches [
        let dist distancexy 0 0
        if dist <= 10 [
          if (pxcor mod 3 = 0) or (pycor mod 3 = 0) [
            set pcolor brown
            set is-road? true
          ]
        ]
        if dist > 10 and dist < 12 [
          set pcolor brown
          set is-road? true
        ]
        if dist >= 12 [
          if (pxcor mod 12 = 0) or (pycor mod 12 = 0) [
            set pcolor brown
            set is-road? true
          ]
        ]
      ]
    ]

    road-scenario = "norrkoping" [
      ask patches [
        if (pxcor mod 12 = 0) or (pycor mod 12 = 0) [ 
          set pcolor brown 
          set is-road? true
        ]
        if abs (pycor - ( 8 * sin (pxcor * 5) )) < 2 [ 
          set pcolor blue 
          set is-road? false
          set is-river? true
        ]
        if abs (pxcor + 5) < 1 [ 
          set pcolor brown 
          set is-road? true
          set is-river? false
        ]
      ]
    ]

    road-scenario = "stockholm" [
      ask patches [
        let dist distancexy 0 0
        if dist > 8 and dist < 13 [ 
          set pcolor blue 
          set is-road? false
          set is-river? true
        ]
        if (pxcor mod 10 = 0) or (pycor mod 10 = 0) [ 
          set pcolor brown 
          set is-road? true
          set is-river? false
        ]
      ]
    ]

    road-scenario = "real-norrkoping" [
      ask patches [set pcolor gray + 4]
      ifelse ( file-exists? "waterways.shp" ) [
        set water-dataset gis:load-dataset "waterways.shp"
        gis:set-world-envelope (gis:envelope-of water-dataset)
        gis:set-drawing-color blue
        gis:draw water-dataset 1
        display
        foreach gis:feature-list-of water-dataset [ feature ->
          ask patches gis:intersecting feature [ 
            set is-river? true
            set is-road? false
            set pcolor blue
          ]
        ]
      ] [ ]

      ifelse ( file-exists? "roads.shp" ) [
        set road-dataset gis:load-dataset "roads.shp"
        gis:set-world-envelope (gis:envelope-of road-dataset)
        gis:set-drawing-color brown
        gis:draw road-dataset 1
        display
        load-gis-logic road-dataset
      ] [ ]

      ifelse ( file-exists? "buildings.shp" ) [
        set building-dataset gis:load-dataset "buildings.shp"
        gis:set-world-envelope (gis:envelope-of building-dataset)
        gis:set-drawing-color orange
        gis:fill building-dataset 1.0
        display
        foreach gis:feature-list-of building-dataset [ feature ->
          ask patches gis:intersecting feature [ 
            set is-building? true
            set pcolor orange
          ]
        ]
      ] [ ]
    ]
  )
end

to load-gis-logic [ dataset ]
  foreach gis:feature-list-of dataset [ feature ->
    ask patches gis:intersecting feature [ 
      ;; Force road to overwrite river
      set is-road? true 
      set is-river? false
      set pcolor brown
    ]
  ]
end

to initialize-tract-habitable-counts
  let tracts-to-update patches with [ (pxcor mod 10 = 0) and (pycor mod 10 = 0) ]
  ask tracts-to-update [
    set tract-habitable-count count (patches in-radius 5) with [is-habitable?]
  ]
end

to apply-intervention-scenario
  (ifelse
    intervention-scenario = "none" [ ]

    intervention-scenario = "central-park" [
      ask parks [ die ]
      ask patches with [is-green?] [
        if not is-road? and not is-river? [ set pcolor black ]
        set is-green? false
        set my-park-id nobody
      ]
      create-parks 1 [
        set shape "tree"
        set color green
        set size 4
        move-to patch 0 0
        set my-patches (patches in-radius (max-pxcor / 3)) with [not is-road? and not is-river?]
        ask my-patches [
          set pcolor green + 2
          set is-green? true
          set my-park-id [who] of myself
        ]
        set my-attendees (turtle-set nobody)
      ]
    ]

    intervention-scenario = "venue-hubs" [
      let q-x floor (max-pxcor / 2)
      let q-y floor (max-pycor / 2)
      let hub-centers (list patch (- q-x) (- q-y) patch q-x (- q-y) patch (- q-x) q-y patch q-x q-y)
      let i 0
      ask venues [
        let target-hub item (i mod 4) hub-centers
        let possible-spots (patches in-radius 5) with [is-habitable?]
        ifelse any? possible-spots [ move-to one-of possible-spots ] [ move-to target-hub ]
        set i i + 1
      ]
    ]

    intervention-scenario = "bridge-parks" [
      ask parks [ die ]
      ask patches with [is-green?] [
        if not is-road? and not is-river? [ set pcolor black ]
        set is-green? false
        set my-park-id nobody
      ]
      let river-patches patches with [is-river?]
      if any? river-patches [
        ask river-patches with [(pxcor mod 8 = 0) and (pycor mod 8 = 0)] [
          sprout-parks 1 [
            set shape "tree"
            set color green
            set size 2
            set my-patches (patches in-radius 2)
            ask my-patches [
              set pcolor green + 2
              set is-green? true
              set is-river? false 
              set my-park-id [who] of myself
            ]
            set my-attendees (turtle-set nobody)
          ]
        ]
      ]
    ]

    intervention-scenario = "mixed-grid" [
      ask parks [ die ]
      ask patches with [is-green?] [
         if not is-road? and not is-river? [ set pcolor black ]
         set is-green? false
         set my-park-id nobody
      ]
      ask venues [ die ]
      let spacing 8
      
      ask patches with [pxcor mod spacing = 0 and pycor mod spacing = 0 and is-habitable?] [
        sprout-parks 1 [
          set shape "tree"
          set color green
          set size 2
          set my-patches (patches in-radius 1.5) with [not is-road? and not is-river?]
          ask my-patches [
            set pcolor green + 2
            set is-green? true
            set my-park-id [who] of myself
          ]
          set my-attendees (turtle-set nobody)
        ]
      ]
      
      ask patches with [(pxcor + (spacing / 2)) mod spacing = 0 and (pycor + (spacing / 2)) mod spacing = 0 and is-habitable?] [
        sprout-venues 1 [
          set shape "house"
          set color (item (random number-of-ethnicities) colors)
          set size 2
          set my-venue-exclusivity venue-exclusivity
          set my-venue-obligatoriness 1
          set my-attendees (turtle-set nobody)
        ]
      ]
    ]
    
    intervention-scenario = "majority-spread-minority-hubs" [
      let majority-color item 0 colors
      let q-x floor (max-pxcor / 2)
      let minority-hubs (list patch (- q-x) 0 patch q-x 0)
      let i 0
      ask venues [
        ifelse color = majority-color [
          let possible-spots habitable-patches
          if any? possible-spots [ move-to one-of possible-spots ]
        ] [
          let target-hub item (i mod 2) minority-hubs
          let possible-spots ([patches in-radius 5] of target-hub) with [is-habitable?]
          ifelse any? possible-spots [ move-to one-of possible-spots ] [ move-to target-hub ]
          set i i + 1
        ]
      ]
    ]

    intervention-scenario = "integrated-venues" [
      let num-colors length colors
      let num-clusters ceiling (count venues / num-colors)
      let actual-clusters num-clusters
      if actual-clusters > count habitable-patches [ set actual-clusters count habitable-patches ]
      
      if actual-clusters > 0 [
        let cluster-centers [self] of n-of actual-clusters habitable-patches
        foreach colors [ c ->
          let venues-of-color venues with [color = c]
          let i 0
          ask venues-of-color [
            let target-center item (i mod actual-clusters) cluster-centers
            let possible-spots ([patches in-radius 3] of target-center) with [is-habitable?]
            ifelse any? possible-spots [ move-to one-of possible-spots ] [ move-to target-center ]
            set i i + 1
          ]
        ]
      ]
    ]
  )
end

;; --- LOGIC UPDATES ---

to evaluate-venues-and-parks
  ask venues [ set my-attendees (turtle-set nobody) ]
  ask parks [ set my-attendees (turtle-set nobody) ]
  ask patches with [is-road?] [ set my-commuters (turtle-set nobody) ]

  ask families [
    let reachable-area get-reachable-network patch-here travel-distance road-multiplier
    
    set visited-roads reachable-area with [is-road?]

    ;; VENUES
    let possible-venues venues-on reachable-area
    let open-venues-group possible-venues with [color = [color] of myself]
    let open-venues-adventure possible-venues with [color != [color] of myself and my-venue-exclusivity < [my-adventurousness] of myself]

    let open-venues (turtle-set open-venues-group open-venues-adventure)
    set visited-venues open-venues with [1 - my-venue-obligatoriness < [my-commitment] of myself]
    
    ;; PARKS
    set visited-parks parks-on reachable-area
    
    ;; Add to attendees
    let family-agent self
    if any? visited-venues [
      ask visited-venues [ set my-attendees (turtle-set my-attendees family-agent) ]
    ]
    if any? visited-parks [
      ask visited-parks [ set my-attendees (turtle-set my-attendees family-agent) ]
    ]
    if any? visited-roads [
      ask visited-roads [ set my-commuters (turtle-set my-commuters family-agent) ]
    ]
  ]
  
  rebuild-all-rays
end

to rebuild-all-rays
  ask rays [ die ]
  ask families [
    let my-candidates other families in-radius neighborhood-distance with [who > [who] of myself]
    ask my-candidates [
      if has-line-of-sight? myself [
        create-ray-with myself [ hide-link ]
      ]
    ]
  ]
end

to update-families
  ask families [
    let visible-candidates ray-neighbors
    
    set total-nearby count visible-candidates
    set similar-nearby count visible-candidates with [color = [color] of myself]
    
    let val1 0
    if beta1-neighbors != 0 [ set val1 calculate-similarity visible-candidates ]

    let val2 0
    if beta2-venue-group != 0 [
      let group2 (turtle-set [my-attendees] of visited-venues)
      set group2 other group2 
      set val2 calculate-similarity group2
    ]

    let val3 0
    if beta3-venue-loc != 0 [
      let group3 (turtle-set [other families in-radius neighborhood-distance] of visited-venues)
      set val3 calculate-similarity group3
    ]

    let val4 0
    if beta4-home-venues != 0 [
      let local-venues venues in-radius neighborhood-distance
      let group4 (turtle-set [my-attendees] of local-venues)
      set group4 other group4 
      set val4 calculate-similarity group4
    ]

    let val5 0
    if beta5-park-group != 0 [
      let group5 (turtle-set [my-attendees] of visited-parks)
      set group5 other group5
      set val5 calculate-similarity group5
    ]

    let val6 0
    if beta6-roads-group != 0 [
      let group6 (turtle-set [my-commuters] of visited-roads)
      set group6 other group6
      set val6 calculate-similarity group6
    ]

    let weights-sum (beta1-neighbors + beta2-venue-group + beta3-venue-loc + beta4-home-venues + beta5-park-group + beta6-roads-group)
    let eps random-normal 0 0.1 
    let weighted-score (val1 * beta1-neighbors) + (val2 * beta2-venue-group) + (val3 * beta3-venue-loc) + (val4 * beta4-home-venues) + (val5 * beta5-park-group) + (val6 * beta6-roads-group)

    ifelse weights-sum > 0 [ set my-utility (weighted-score / weights-sum) + eps ] [ set my-utility eps ]
  ]
end

to-report calculate-similarity [ target-group ]
  if not any? target-group [ report 0.5 ]
  let total-count count target-group
  let similar-count count target-group with [color = [color] of myself]
  report (similar-count / total-count)
end

;; --- MOVEMENT & HAPPINESS DISTRIBUTION ---

to move-unhappy-families
  let num-to-move ceiling (count families * 0.10)
  if num-to-move > 0 [
    let sorted-families sort-by [ [f1 f2] -> [my-utility] of f1 < [my-utility] of f2 ] families
    let least-happy sublist sorted-families 0 num-to-move
    ask families [ set happy? true ]
    ask turtle-set least-happy [ 
      set happy? false
      find-new-spot 
    ]
  ]
end

to find-new-spot
  ;; Evaluate exactly which patches are reachable by walking + driving network
  let reachable-area get-reachable-network patch-here travel-distance road-multiplier
  let candidates reachable-area with [is-habitable? and not any? turtles-on self]
  
  if not any? candidates [ stop ]
  let target one-of candidates
  
  if target != nobody [
    ;; Draw simple line for traffic heatmapping (avoids heavy A* pathing calculations)
    let final-path get-path-patches target
    ask final-path with [is-road?] [ set traffic traffic + 1 ]
    
    let family-agent self
    if visited-venues != nobody and any? visited-venues [
      ask visited-venues [ set my-attendees my-attendees with [self != family-agent] ]
    ]
    if visited-parks != nobody and any? visited-parks [
      ask visited-parks [ set my-attendees my-attendees with [self != family-agent] ]
    ]
    if visited-roads != nobody and any? visited-roads [
      ask visited-roads [ set my-commuters my-commuters with [self != family-agent] ]
    ]
    
    ask my-rays [ die ]
    move-to target

    ;; Evaluate dynamically at the new location
    let new-reachable-area get-reachable-network patch-here travel-distance road-multiplier
    set visited-roads new-reachable-area with [is-road?]

    let possible-venues venues-on new-reachable-area
    let open-venues-group possible-venues with [color = [color] of myself]
    let open-venues-adventure possible-venues with [color != [color] of myself and my-venue-exclusivity < [my-adventurousness] of myself]
    let open-venues (turtle-set open-venues-group open-venues-adventure)
    
    set visited-venues open-venues with [1 - my-venue-obligatoriness < [my-commitment] of myself]
    set visited-parks parks-on new-reachable-area

    if any? visited-venues [
      ask visited-venues [ set my-attendees (turtle-set my-attendees family-agent) ]
    ]
    if any? visited-parks [
      ask visited-parks [ set my-attendees (turtle-set my-attendees family-agent) ]
    ]
    if any? visited-roads [
      ask visited-roads [ set my-commuters (turtle-set my-commuters family-agent) ]
    ]

    let my-candidates other families in-radius neighborhood-distance
    ask my-candidates [
      if has-line-of-sight? myself [
        create-ray-with myself [ hide-link ]
      ]
    ]
  ]
end

to-report has-line-of-sight? [ target ]
  let dist distance target
  if dist = 0 [ report true ]
  let ang towards target
  let step 1.0
  let current-dist step
  while [current-dist < dist] [
    let p patch-at-heading-and-distance ang current-dist
    if p = nobody [ report false ]
    if [is-river?] of p [ report false ]
    set current-dist current-dist + step
  ]
  report true
end

to-report get-path-patches [ target ]
  let dist distance target
  if dist = 0 [ report patch-set patch-here ]
  let ang towards target
  let step 0.5 
  let current-dist step
  let p-set (patch-set patch-here)
  while [current-dist <= dist] [
    let p patch-at-heading-and-distance ang current-dist
    if p != nobody [ set p-set (patch-set p-set p) ]
    set current-dist current-dist + step
  ]
  report p-set
end


;; --- STATISTICAL METRICS: MASSEY & DENTON (1988) ---
to calculate-segregation-dimensions
  let gx-color item 0 colors
  let pop-x count families with [color = gx-color]
  let pop-y count families with [color != gx-color]
  let pop-t count families
  
  if pop-x = 0 or pop-y = 0 or pop-t = 0 [ stop ]

  let iso-sum sum [ similar-nearby / total-nearby ] of families with [color = gx-color and total-nearby > 0]
  set index-exposure (iso-sum / pop-x)

  let tracts patches with [ (pxcor mod 10 = 0) and (pycor mod 10 = 0) ]
  let total-area count habitable-patches
  
  let d-sum 0
  let delta-sum 0
  
  ask tracts [
    let local-fam families in-radius 5
    let x_i count local-fam with [color = gx-color]
    let y_i count local-fam with [color != gx-color]
    let a_i tract-habitable-count  
    
    set d-sum d-sum + abs ( (x_i / pop-x) - (y_i / pop-y) )
    if total-area > 0 [
       set delta-sum delta-sum + abs ( (x_i / pop-x) - (a_i / total-area) )
    ]
  ]
  set index-dissimilarity (d-sum / 2)
  set index-concentration (delta-sum / 2)
  
  let n_random 150  
  let sample-x n-of (ifelse-value (pop-x > n_random) [n_random] [pop-x]) families with [color = gx-color]
  let sample-y n-of (ifelse-value (pop-y > n_random) [n_random] [pop-y]) families with [color != gx-color]
  let sample-t n-of (ifelse-value (pop-t > n_random) [n_random] [pop-t]) families
  
  let pxx mean [ mean [ exp (- distance myself) ] of sample-x ] of sample-x
  let pyy mean [ mean [ exp (- distance myself) ] of sample-y ] of sample-y
  let ptt mean [ mean [ exp (- distance myself) ] of sample-t ] of sample-t
  
  ifelse ptt > 0 [
     set index-clustering ( (pop-x * pxx + pop-y * pyy) / (pop-t * ptt) )
  ] [
     set index-clustering 0
  ]
end

to update-globals
  let sum-similar sum [similar-nearby] of families
  let sum-total sum [total-nearby] of families

  ifelse sum-total = 0
    [ set percent-similar 100 ]
    [ set percent-similar (sum-similar / sum-total) * 100 ]

  set average-utility mean [my-utility] of families
  set percent-unhappy (count families + 1) / (count families with [not happy?] + 1)
  
  calculate-segregation-dimensions
end

;; --- MANUAL PLACEMENT ---

to place-temporary-venue
  if mouse-down? [
    ask patches with [pcolor = lime] [ set pcolor black ]
    let target-patch patch mouse-xcor mouse-ycor
    ifelse temp-venue = nobody [
      create-venues 1 [
        set temp-venue self
        set shape "house"
        move-to target-patch
      ]
    ]
    [ ask temp-venue [ move-to target-patch ] ]
    
    ask temp-venue [
      set color (item (random number-of-ethnicities) colors) 
      set my-venue-exclusivity venue-exclusivity
      set my-venue-obligatoriness 1
      ask patches in-radius venue-catchment-distance [ set pcolor lime ]
    ]
    while [mouse-down?] [ every 0.1 [] ]
    display
  ]
end

to confirm-venue-placement
  ifelse temp-venue != nobody [
    set temp-venue nobody
    ask patches [ set pcolor black ]
    ask venues [ set pcolor white ]
    evaluate-venues-and-parks
    update-families
    update-globals
    user-message "Venue Confirmed."
  ]
  [ user-message "No temporary venue found to confirm." ]
end

to draw-roads
  if mouse-down? [
    ask patch mouse-xcor mouse-ycor [
      set pcolor brown
      set is-road? true
      set is-river? false
      set traffic 0
      ask families-here [ find-new-spot ]
      set my-commuters (turtle-set nobody)
    ]
    set environment-changed? true
    display
  ]
end

to erase-patch
  if mouse-down? [
    ask patch mouse-xcor mouse-ycor [
      ;; Reset color to background
      set pcolor black
      
      ;; Turn off all properties
      set is-road? false 
      set is-river? false
      set is-green? false
      set traffic 0
      set my-park-id nobody
      
      ;; Clean up network arrays
      ask parks [ set my-patches my-patches with [self != myself] ]
      
      ;; Destroy structures
      ask venues-here [ die ]
      ask parks-here [ die ]
    ]
    set environment-changed? true
    display
  ]
end

to grow-parks
  if mouse-down? [
    ask patch mouse-xcor mouse-ycor [
      set pcolor green + 2
      set is-green? true
      set is-road? false
      set is-river? false
      
      ifelse any? parks in-radius 10 [
        let nearest-park min-one-of (parks in-radius 10) [distance myself]
        if nearest-park != nobody [
          set my-park-id [who] of nearest-park
          ask nearest-park [ set my-patches (patch-set my-patches myself) ]
        ]
      ]
      [
        sprout-parks 1 [
          set shape "tree"
          set color green
          set size 2
          set my-patches (patch-set patch-here)
          set my-attendees (turtle-set nobody)
        ]
        set my-park-id [who] of one-of parks-here
      ]
    ]
    set environment-changed? true
    display
  ]
end]]></code>
