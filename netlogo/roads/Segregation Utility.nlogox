    <slider x="1140" step="0.1" y="266" max="1" width="187" display="beta3-venue-loc" height="50" min="0" direction="Horizontal" default="0.1" variable="beta3-venue-loc"></slider>
    <slider x="1135" step="0.1" y="338" max="1" width="217" display="beta4-home-venues" height="50" min="0" direction="Horizontal" default="0.1" variable="beta4-home-venues"></slider>
    <plot x="1100" autoPlotX="true" yMax="10.0" autoPlotY="true" y="480" xMin="0.0" height="175" legend="false" xMax="1.0" yMin="0.0" width="230" display="utility">
      <setup></setup>
      <update></update>
      <pen interval="0.1" mode="1" display="default" color="-16777216" legend="true">
        <setup></setup>
        <update>histogram [my-utility] of families</update>
      </pen>
      <pen interval="1.0" mode="0" display="pen-1" color="-612749" legend="true">
        <setup></setup>
        <update>plotxy utility-threshold 0
plotxy utility-threshold plot-y-max</update>
      </pen>
    </plot>
    <chooser x="480" y="605" height="60" variable="visual-mode" current="0" width="250" display="visual-mode">
