<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[breed [families family]
breed [venues venue]

globals [
  percent-similar
  percent-unhappy
  colors
  temp-venue
  
  ;; New lists for hyper mode and names
  hyper-person-shapes
  hyper-house-shapes
  names-list
]

families-own [
  happy?
  my-utility          ;; The calculated utility score
  
  ;; New visual and identity variables
  my-name
  my-hyper-shape

  ;; Standard variables
  my-%-similar-wanted
  my-catchment-distance
  my-adventurousness
  my-commitment
  visited-venues
]

venues-own [
  my-venue-exclusivity
  my-venue-obligatoriness
  my-attendees        ;; An agentset of families currently visiting this venue
  my-hyper-shape      ;; New variable for hyper mode
]

to setup
  clear-all
  set colors [red green yellow blue orange]
  set temp-venue nobody
  
  ;; Initialize lists for Hyper mode and Names
  setup-lists

  ask n-of number patches [ sprout-families 1 ]
  ask n-of venues-number patches [ sprout-venues 1 ]

  ask families [
    set color (item (random number-of-ethnicities) colors)
    set my-%-similar-wanted %-similar-wanted
    set my-catchment-distance catchment-distance
    set my-adventurousness random-float 1
    set my-commitment random-float 1
    set visited-venues (turtle-set nobody)
    
    ;; New identity assignments
    set my-name one-of names-list
    set my-hyper-shape one-of hyper-person-shapes
  ]

  ask venues [
    set shape "house"
    set color (item (random number-of-ethnicities) colors)
    set pcolor white
    set my-venue-exclusivity venue-exclusivity
    set my-venue-obligatoriness 1
    set my-attendees (turtle-set nobody)
    
    ;; New identity assignments
    set my-hyper-shape one-of hyper-house-shapes
  ]

  evaluate-venues ;; Run once to populate attendees
  update-families
  update-visuals  ;; Apply the selected visual mode
  update-globals
  reset-ticks
end

to go
  ;if all? families [happy?] [ stop ]
  evaluate-venues
  move-unhappy-families
  update-families
  update-visuals       ;; Update looks every tick (in case mode changes or happiness changes)
  check-mouse-interaction ;; Check for clicks on families
  update-globals
  tick
end

;; --- VISUALS & INTERACTION ---

to update-visuals
  if visual-mode = "abstract" [
    ask venues [ set shape "star" ]
    ask families [
      ifelse happy? 
        [ set shape "square" ]
        [ set shape "x" ]
    ]
  ]

  if visual-mode = "stylized" [
    ask venues [ set shape "house" ]
    ask families [ set shape "person" ]
  ]

  if visual-mode = "hyper" [
    ask venues [ 
      ;; Fallback to "house" if specific shapes aren't imported
      carefully [set shape my-hyper-shape] [set shape "house"] 
    ]
    ask families [ 
      ;; Fallback to "person" if specific shapes aren't imported
      carefully [set shape my-hyper-shape] [set shape "person"]
    ]
  ]
end

to check-mouse-interaction
  ;; Only run if mouse is clicked, we aren't placing a venue, and we aren't dragging
  if mouse-down? and temp-venue = nobody [
    
    ;; Find a family close to the mouse click
    let clicked-family min-one-of families with [distancexy mouse-xcor mouse-ycor < 1.5] [distancexy mouse-xcor mouse-ycor]
    
    if clicked-family != nobody [
      ask clicked-family [
        ;; Gather friends (people in my venues, excluding myself)
        let my-friends (turtle-set [my-attendees] of visited-venues)
        set my-friends other my-friends
        
        let friend-names map [i -> [my-name] of i] (sort my-friends)
        let friend-string ""
        
        ;; Ensure friend-names is not an empty list
        let friend-string-message ""
        if (count friend-names) > 0 [
          set friend-string-message (word (up-to-n-of 5 friend-names))
        ]


        ;; Show info in console
        print "-----------------------------"
        print (word "Name: " my-name)
        print (word "Ethnicity (Color): " color)
        print (word "Happy?: " happy?)
        print (word "Friends: " friend-string-message)
        
        ;; Show speech bubble visual
        user-message (word "Hi, I am " my-name ".\n"
                      "I am a " [color] of self " family.\n"
                      "Am I happy? " happy? "\n"
                      "Some of my friends are: " friend-string-message)
      ]
      
      ;; Wait for mouse release to prevent spamming
      while [mouse-down?] [ ]
    ]
  ]
end

to setup-lists
  ;; Names generated randomly
  set names-list ["Alex" "Jordan" "Taylor" "Morgan" "Casey" "Riley" "Jamie" "Quinn" "Avery" "Peyton" 
                  "Charlie" "Sam" "Dakota" "Skyler" "Reese" "Cameron" "Finley" "Rowan" "Emerson" "Tatum"
                  "Hayden" "Sawyer" "Parker" "Hunter" "Blake" "Dallas" "Phoenix" "River" "Sage" "Logan"]

  ;; Shapes for Hyper Mode
  ;; NOTE: These must be imported in the Turtle Shapes Editor for Hyper mode to work fully
  set hyper-person-shapes [
    "person" "person doctor" "person farmer" "person graduate" 
    "person lumberjack" "person police" "person service" 
    "person soldier" "person student"
  ]
  
  set hyper-house-shapes [
    "house" "house bungalow" "house colonial" 
    "house efficiency" "house ranch" "house two story"
  ]
end

;; --- LOGIC UPDATES ---

to evaluate-venues
  ;; 1. Families choose venues
  ask families [
    let possible-venues venues in-radius my-catchment-distance
    let open-venues-group possible-venues with [color = [color] of myself]
    let open-venues-adventure possible-venues with [color != [color] of myself and my-venue-exclusivity < [my-adventurousness] of myself]

    let open-venues (turtle-set open-venues-group open-venues-adventure )

    ;; Update visited venues
    set visited-venues open-venues with [1 - my-venue-obligatoriness < [my-commitment] of myself]
  ]

  ;; 2. Venues update their attendee list
  ask venues [
    set my-attendees families with [member? myself visited-venues]
  ]
end

to update-families
  ask families [

    ;; --- FACTOR 1: Agents in my Neighborhood ---
    ;; Who lives near me?
    let group1 other families in-radius neighborhood-distance
    let val1 calculate-similarity group1

    ;; --- FACTOR 2: Agents in my Venues ---
    ;; Who is inside the venues I visit?
    let group2 (turtle-set [my-attendees] of visited-venues)
    set group2 other group2 ;; Remove myself from the count
    let val2 calculate-similarity group2

    ;; --- FACTOR 3: Agents around my Venues ---
    ;; Who lives near the places I go? (Environmental context of the venue)
    let group3 (turtle-set [other families in-radius neighborhood-distance] of visited-venues)
    let val3 calculate-similarity group3

    ;; --- FACTOR 4: Agents coming to my Neighborhood ---
    ;; Who is visiting the venues near my house? (Influx of strangers)
    let local-venues venues in-radius neighborhood-distance
    let group4 (turtle-set [my-attendees] of local-venues)
    set group4 other group4 ;; Remove myself
    let val4 calculate-similarity group4

    ;; --- CALCULATE UTILITY ---
    ;; Formula: Weighted Average of the 4 factors
    let weights-sum (beta1-neighbors + beta2-venue-group + beta3-venue-loc + beta4-home-venues)
    let weighted-score (val1 * beta1-neighbors) + (val2 * beta2-venue-group) + (val3 * beta3-venue-loc) + (val4 * beta4-home-venues)

    ;; Avoid division by zero if all sliders are 0
    ifelse weights-sum > 0 [
      set my-utility (weighted-score / weights-sum)
    ]
    [
      set my-utility 0 ;; Or 1, depending on how you define "no preference"
    ]

    ;; --- DETERMINE HAPPINESS ---
    set happy? (my-utility >= utility-threshold)
  ]
end

;; --- HELPER REPORTER ---
;; Calculates the percentage of agents in a group that share my color
to-report calculate-similarity [ target-group ]
  ;; If the group is empty (e.g., no one is at the venue),
  ;; we report 0.5 (neutral) to avoid penalizing the agent for empty spaces.
  if not any? target-group [ report 0.5 ]

  let total-count count target-group
  let similar-count count target-group with [color = [color] of myself]

  report (similar-count / total-count)
end

to move-unhappy-families
  ask families with [ not happy? ]
    [ find-new-spot ]
end

to find-new-spot
  let valid-spots patches with [not any? turtles-here]
  if any? valid-spots [
    move-to one-of valid-spots
  ]
end

to update-globals
  ;; Updated to reflect utility if needed, or keep standard segregation stats
  let similar-neighbors sum [ count (other families in-radius neighborhood-distance) with [color = [color] of myself] ] of families
  let total-neighbors sum [ count other families in-radius neighborhood-distance ] of families

  ifelse total-neighbors > 0 [
    set percent-similar (similar-neighbors / total-neighbors) * 100
  ] [ set percent-similar 0 ]

  set percent-unhappy (count families with [not happy?]) / (count families) * 100
end

;; --- MANUAL PLACEMENT ---

to place-temporary-venue
    if mouse-down? [
    ask patches with [pcolor = lime] [ set pcolor black ]
    let target-patch patch mouse-xcor mouse-ycor
    ifelse temp-venue = nobody [
      create-venues 1 [
        set temp-venue self
        set shape "house"
        move-to target-patch
      ]
    ]
    [
      ask temp-venue [
        move-to target-patch
      ]
    ]
    ask temp-venue [
      set color (item (random number-of-ethnicities) colors) 
      set my-venue-exclusivity venue-exclusivity
      set my-venue-obligatoriness 1
      ask patches in-radius catchment-distance [
        set pcolor lime
      ]
    ]
    while [mouse-down?] [ every 0.1 [] ]
    display
  ]
end

to confirm-venue-placement
  ifelse temp-venue != nobody [
    set temp-venue nobody
    ask patches [ set pcolor black ]
    ask venues [ set pcolor white ]
    evaluate-venues
    update-families
    update-globals
    user-message "Venue Confirmed."
  ]
  [
    user-message "No temporary venue found to confirm."
  ]
end]]></code>
  <widgets>
    <view x="295" wrappingAllowedX="true" y="10" frameRate="30.0" minPycor="-25" height="485" showTickCounter="true" patchSize="9.4314" fontSize="10" wrappingAllowedY="true" width="485" tickCounterLabel="ticks" maxPycor="25" updateMode="1" maxPxcor="25" minPxcor="-25"></view>
    <monitor x="555" precision="1" y="505" height="60" fontSize="11" width="113" display="Percent Unhappy">percent-unhappy</monitor>
    <monitor x="428" precision="1" y="505" height="60" fontSize="11" width="108" display="Percent Similar">percent-similar</monitor>
    <plot x="10" autoPlotX="true" yMax="100.0" autoPlotY="true" yAxis="%" y="238" xMin="0.0" height="175" legend="false" xMax="25.0" yMin="0.0" width="249" xAxis="time" display="Percent Similar">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="percent" color="-2674135" legend="true">
        <setup></setup>
        <update>plot percent-similar</update>
      </pen>
    </plot>
    <plot x="10" autoPlotX="true" yMax="100.0" autoPlotY="true" yAxis="%" y="418" xMin="0.0" height="175" legend="false" xMax="25.0" yMin="0.0" width="249" xAxis="time" display="Percent Unhappy">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="percent" color="-10899396" legend="true">
        <setup></setup>
        <update>plot percent-unhappy</update>
      </pen>
    </plot>
    <slider x="15" step="10" y="62" max="2500" width="225" display="number" height="50" min="500" direction="Horizontal" default="2270.0" variable="number"></slider>
    <slider x="15" step="1.0" y="119" max="100.0" width="225" display="%-similar-wanted" height="50" min="0.0" direction="Horizontal" default="30.0" variable="%-similar-wanted" units="%"></slider>
    <button x="34" y="14" height="40" disableUntilTicks="false" forever="false" kind="Observer" width="80" display="setup">setup</button>
    <button x="124" y="14" height="40" disableUntilTicks="true" forever="true" kind="Observer" width="80" display="go">go</button>
    <slider x="35" step="1" y="605" max="5" width="192" display="number-of-ethnicities" height="50" min="2" direction="Horizontal" default="2.0" variable="number-of-ethnicities"></slider>
    <slider x="15" step="1" y="176" max="100" width="225" display="%-different-wanted" height="50" min="0" direction="Horizontal" default="0.0" variable="%-different-wanted" units="%"></slider>
    <slider x="244" step="1" y="605" max="20" width="173" display="neighborhood-distance" height="50" min="1" direction="Horizontal" default="2.0" variable="neighborhood-distance"></slider>
