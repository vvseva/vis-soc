    <slider x="815" step="1" y="103" max="20" width="173" display="catchment-distance" height="50" min="0" direction="Horizontal" default="11.0" variable="catchment-distance"></slider>
    <slider x="815" step="0.1" y="178" max="1" width="222" display="venue-exclusivity" height="50" min="0.0" direction="Horizontal" default="1.0" variable="venue-exclusivity"></slider>
    <chooser x="815" y="316" height="60" variable="new-venue-color" current="0" width="157" display="new-venue-color">
      <choice type="double" value="15.0"></choice>
      <choice type="double" value="55.0"></choice>
      <choice type="double" value="45.0"></choice>
      <choice type="double" value="105.0"></choice>
